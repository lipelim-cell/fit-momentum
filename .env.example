# ====================================
# FIT MOMENTUM - VARIÁVEIS DE AMBIENTE
# ====================================

# SERVIDOR
NODE_ENV=development
PORT=3000

# ====================================
# BANCO DE DADOS
# ====================================

# PostgreSQL (Railway gera automaticamente)
DATABASE_URL=postgresql://postgres:password@localhost:5432/fit_momentum

# Redis (Railway gera automaticamente)
REDIS_URL=redis://localhost:6379

# ====================================
# WHATSAPP BUSINESS API
# ====================================

# Meta (Facebook) - Opção recomendada
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id
WHATSAPP_ACCESS_TOKEN=seu_access_token
WHATSAPP_VERIFY_TOKEN=seu_verify_token_secreto

# Chave secreta do app (Meta for Developers > Configurações do App > Básico > Chave Secreta do Aplicativo)
# Usada para validar a assinatura HMAC (X-Hub-Signature-256) dos webhooks recebidos.
META_APP_SECRET=seu_app_secret_aqui

# Twilio - Alternativa
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxxx
# TWILIO_WHATSAPP_NUMBER=+14155238886

# Telefone do admin (com DDI/DDD, ex.: 5511999998888) - recebe notificação de novo comprovante de pagamento
ADMIN_PHONE=seu_telefone_admin_aqui

# ====================================
# INTELIGÊNCIA ARTIFICIAL
# ====================================

# Provedor usado para gerar os treinos: anthropic (padrão) | deepseek
AI_PROVIDER=anthropic

# Claude (Anthropic) - Recomendado
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
# Alternativa mais barata mantendo a Anthropic: claude-haiku-4-5

# DeepSeek - Alternativa mais barata (API compatível com OpenAI)
# Atenção LGPD: o prompt envia dado de saúde (restrições/lesões) para fora do Brasil/EUA
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI - Alternativa
# OPENAI_API_KEY=sk-xxxxx

# ====================================
# YOUTUBE API (Vídeos)
# ====================================

# Opcional - para buscar vídeos automaticamente
YOUTUBE_API_KEY=AIzaSyxxxxx

# ====================================
# PAGAMENTOS
# ====================================

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Mercado Pago (Brasil)
# MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxx
# MERCADOPAGO_PUBLIC_KEY=TEST-xxxxx

# ====================================
# SEGURANÇA
# ====================================

# JWT para autenticação admin
JWT_SECRET=seu_jwt_secret_muito_seguro_aqui

# API key estática para proteger as rotas /api (gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_API_KEY=gere_uma_chave_forte_aqui

# ====================================
# LOGS
# ====================================

LOG_LEVEL=info
# Opções: error, warn, info, debug

# ====================================
# FEATURES (Ativar/Desativar)
# ====================================

ENABLE_DAILY_WORKOUTS=true
ENABLE_FEEDBACK_COLLECTION=true
ENABLE_PAYMENT_INTEGRATION=false
ENABLE_VIDEO_SEARCH=true

# ====================================
# HORÁRIOS (Cron Jobs)
# ====================================

# Horário de envio de treinos (formato: hora minuto)
WORKOUT_SEND_TIME_HOUR=6
WORKOUT_SEND_TIME_MINUTE=0

# Horário de coleta de feedback
FEEDBACK_COLLECT_TIME_HOUR=20
FEEDBACK_COLLECT_TIME_MINUTE=0

# ====================================
# LIMITES E CONFIGURAÇÕES
# ====================================

# Máximo de tentativas de envio de mensagem
MAX_MESSAGE_RETRY=3

# Delay entre mensagens (ms) - evitar spam
MESSAGE_DELAY_MS=2000

# Cache TTL (Time To Live) em segundos
CACHE_TTL=3600

# ====================================
# URLs
# ====================================

# URL pública do seu servidor (para webhooks)
PUBLIC_URL=https://seu-app.railway.app

# URL do dashboard admin (opcional)
# ADMIN_DASHBOARD_URL=https://admin.fitmomentum.com

# ====================================
# OBSERVAÇÕES
# ====================================

# 1. NUNCA commite este arquivo com valores reais!
# 2. Use .env para desenvolvimento local
# 3. Configure variáveis diretamente no Railway/Render
# 4. Mantenha backups seguros das suas credenciais
# 5. Regenere tokens periodicamente por segurança
